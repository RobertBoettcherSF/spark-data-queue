--  ============================================================================
--  GNAT PROJECT FILE: test_queue.gpr
--  
--  This project file defines the build configuration for the SPARK Data Queue
--  test suite. It includes all necessary dependencies and settings.
--  
--  Usage:
--    gprbuild -P test_queue.gpr        # Build and run tests
--    gprclean -P test_queue.gpr        # Clean test artifacts
--  
--  ============================================================================

project Test_Queue is
   
   --  Project version
   Version := "0.03";
   
   --  Project description
   Description := "Test suite for SPARK Data Queue";
   
   --  ========================================================================
   --  SOURCE DIRECTORIES
   --  ========================================================================
   
   --  Test source directory
   for Source_Dirs use ("tests", "src/queue");
   
   --  Object directory for build artifacts
   for Object_Dir use "obj";
   
   --  Executable directory
   for Exec_Dir use "bin";
   
   --  Main test executable
   for Main use ("test_queue.adb");
   
   --  ========================================================================
   --  LANGUAGE SETTINGS
   --  ========================================================================
   
   --  Use Ada 2012 standard
   for Language use ("Ada_2012");
   
   --  ========================================================================
   --  COMPILER OPTIONS
   --  ========================================================================
   
   package Compiler is
      for Default_Switches ("Ada") use (
         "-g",              --  Generate debug information
         "-O2",             --  Optimization level 2
         "-gnatn",          --  Enable assertions
         "-gnata",          --  Enable static assertions
         "-gnatwae",        --  Warnings as errors
         "-gnatW8",         --  Enable all warnings
         "-gnatf"           --  Full error messages
      );
   end Compiler;
   
   --  ========================================================================
   --  BINDER OPTIONS
   --  ========================================================================
   
   package Binder is
      for Default_Switches ("Ada") use ("-E");
   end Binder;
   
   --  ========================================================================
   --  LINKER OPTIONS
   --  ========================================================================
   
   package Linker is
      for Default_Switches ("Ada") use ("-static");
   end Linker;

end Test_Queue;
